# Copy to .env and fill in your values
GHL_API_KEY=your-private-integration-token
GHL_LOCATION_ID=your-sub-account-location-id

# Optional paths
# GHL_EXCEL_PATH=sample.xlsx
# MIGRATION_DB_PATH=data/migration.db
# RUN_ID=2026-05-23
# DASHBOARD_PORT=8765
# ATTACHMENTS_DIR=D:\your_folder\attachments_import

# OCR (optional — Script 4)
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
# OCR_LANG=fra+eng
# ANTHROPIC_API_KEY=   # only if client approves cloud OCR fallback

# Workflow:
#   python scripts/01_init_registry.py --excel production.xlsx --run-id 2026-05-23
#   python scripts/05_dashboard_server.py --run-id 2026-05-23
#   python scripts/02_migrate_data.py --run-id 2026-05-23 --setup --audit
#   python scripts/02_migrate_data.py --run-id 2026-05-23
#   python scripts/03_attach_documents.py --run-id 2026-05-23 --attachments-dir D:\attachments_import
#   python scripts/04_ocr_rename.py --run-id 2026-05-23

# GHL: enable Settings → Allow Duplicate Contact
# Registry dedupes by Zoho ID; unique import phones when missing
